{
  "name": "orval-workspaces",
  "version": "8.5.3",
  "private": true,
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "samples/**",
    "tests"
  ],
  "scripts": {
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "format:staged": "lint-staged",
    "format:samples": "oxfmt samples",
    "postinstall": "bun scripts/link-workspace-bins.mjs",
    "prepare": "husky",
    "commitlint": "commitlint",
    "update-samples": "turbo run generate-api",
    "build": "turbo build --filter='./packages/*'",
    "typecheck": "turbo typecheck --filter='./packages/*'",
    "test": "turbo test --filter='./packages/*'",
    "test:cli": "bun run --filter orval-tests clean && bun run --filter orval-tests generate-api && bun run --filter orval-tests build",
    "test:samples": "turbo test --filter='./samples/**' --filter=!react-query-form-data --filter=!react-query-form-url-encoded --filter=!react-query-form-url-encoded-mutator --filter=!react-query-form-data-mutator --filter=!react-query-hook-mutator-axios --filter=!react-query-hook-mutator-fetch",
    "test:snapshots": "turbo run test:snapshots --filter='./samples/**' --filter=orval-tests",
    "test:snapshots:update": "turbo run test:snapshots:update --filter='./samples/**' --filter=orval-tests",
    "lint": "turbo run lint --filter='./packages/*'",
    "lint:samples": "turbo run lint --filter='./samples/**'",
    "dev": "turbo run dev --filter='./packages/*'",
    "clean": "rimraf .turbo",
    "clean:all": "bun run --filter '*' clean",
    "nuke:all": "bun run --filter '*' nuke && rimraf .turbo node_modules"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@types/node": "catalog:",
    "esbuild-plugin-alias": "^0.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "oxlint-tsgolint": "^0.16.0",
    "rimraf": "catalog:",
    "tsdown": "catalog:",
    "turbo": "^2.8.12",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=24",
      "onFail": "error"
    }
  },
  "packageManager": "bun@1.3.9",
  "catalog": {
    "globals": "17.4.0",
    "rimraf": "6.1.2",
    "tslib": "2.8.1",
    "tsdown": "0.20.3",
    "typescript": "5.9.3",
    "npm-run-all2": "8.0.4",
    "vite": "7.2.2",
    "vitest": "4.0.18",
    "@types/node": "22.18.12",
    "@scalar/openapi-types": "0.5.3",
    "oxlint": "1.51.0",
    "prettier": "3.8.1"
  },
  "catalogs": {
    "angular": {
      "@angular/core": "21.1.4",
      "@angular/common": "21.1.4",
      "@angular/compiler": "21.1.4",
      "@angular/compiler-cli": "21.1.4",
      "@angular/animations": "21.1.4",
      "@angular/platform-browser": "21.1.4",
      "@angular/forms": "21.1.4",
      "@angular/router": "21.1.4",
      "rxjs": "7.8.2",
      "@angular/build": "21.1.4",
      "@angular/cli": "21.1.4"
    },
    "axios": {
      "axios": "1.13.6"
    },
    "tooling": {
      "@faker-js/faker": "10.3.0",
      "msw": "2.12.10"
    },
    "hono": {
      "hono": "4.11.9",
      "@hono/zod-validator": "0.7.6"
    },
    "zod3": {
      "zod": "3.25.76"
    },
    "swr": {
      "swr": "2.3.6"
    },
    "vue": {
      "vue": "3.5.26",
      "vue-tsc": "3.2.4",
      "@tanstack/vue-query": "5.92.7"
    },
    "svelte": {
      "svelte": "5.53.0",
      "svelte-check": "3.8.6",
      "@tanstack/svelte-query": "4.41.0"
    },
    "react": {
      "react": "18.3.1",
      "@types/react": "18.3.24",
      "@tanstack/react-query": "5.62.16"
    },
    "mcp": {
      "@modelcontextprotocol/sdk": "1.26.0"
    }
  }
}
