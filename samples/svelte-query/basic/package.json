{
  "name": "svelte-query-basic",
  "version": "8.5.3",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "prepare": "svelte-kit sync",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint .",
    "generate-api": "svelte-kit sync && orval",
    "test:snapshots": "vitest run --config vitest.snapshots.ts",
    "test:snapshots:update": "bun run test:snapshots --update",
    "test": "bun run check"
  },
  "dependencies": {
    "@tanstack/svelte-query": "catalog:svelte",
    "axios": "catalog:axios"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.2",
    "@faker-js/faker": "catalog:tooling",
    "@sveltejs/adapter-auto": "^2.1.1",
    "@sveltejs/kit": "^1.30.4",
    "@types/node": "catalog:",
    "eslint-plugin-svelte": "^3.15.0",
    "msw": "catalog:tooling",
    "orval": "workspace:*",
    "svelte": "catalog:svelte",
    "svelte-check": "catalog:svelte",
    "tslib": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "dependenciesMeta": {
    "msw": {
      "built": true
    }
  },
  "msw": {
    "workerDirectory": "static"
  },
  "scriptsComments": {
    "prepare": "see https://github.com/sveltejs/kit/issues/5390#issuecomment-1176480653"
  }
}
