{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "*.ts"],
  "exclude": [
    "node_modules",
    "__snapshots__",
    "api-generation.spec.ts",
    "vitest.snapshots.ts",
    "orval.config.ts",
    "orval.config.js"
  ]
}
