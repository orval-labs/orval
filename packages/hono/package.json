{
  "name": "@orval/hono",
  "version": "8.0.0-rc.2",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "!dist/**/*.d.ts.map",
    "!dist/**/*.d.mts.map"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "publishConfig": {
    "exports": {
      ".": "./dist/index.mjs",
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build": "tsdown --config-loader unrun",
    "dev": "tsdown --config-loader unrun --watch src",
    "lint": "tsc --noEmit src/zValidator.ts && eslint .",
    "clean": "rimraf .turbo dist",
    "nuke": "rimraf .turbo dist node_modules"
  },
  "dependencies": {
    "@orval/core": "workspace:*",
    "@orval/zod": "workspace:*",
    "fs-extra": "^11.3.2",
    "openapi3-ts": "4.5.0",
    "remeda": "^2.32.0"
  },
  "devDependencies": {
    "@hono/zod-validator": "^0.7.4",
    "@types/fs-extra": "^11.0.4",
    "eslint": "catalog:",
    "rimraf": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  },
  "stableVersion": "8.0.0-rc.1"
}
