{
  "cSpell.words": [
    "axios",
    "Emptyish",
    "hono",
    "listitem",
    "openapi",
    "Orval",
    "Petstore",
    "tanstack",
    "zods"
  ],
  "files.associations": {
    "turbo.json": "jsonc"
  },
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "debug.javascript.terminalOptions": {
    "skipFiles": [
      "**/node_modules/**",
      "<node_internals>/**",
      "**/node/corepack/**"
    ]
  },
  "[mdx]": {
    "editor.defaultFormatter": "unifiedjs.vscode-mdx"
  },
  "[yaml]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[html]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "oxc.enable": true,
  "eslint.enable": false,
  "prettier.enable": false,
  "[json]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  }
}
